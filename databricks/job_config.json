{
  "run_name": "Generate TPC-H SF1000 Data",
  "new_cluster": {
    "spark_version": "13.3.x-scala2.12",
    "node_type_id": "i3.xlarge",
    "num_workers": 8,
    "aws_attributes": {
      "availability": "SPOT_WITH_FALLBACK",
      "zone_id": "us-west-2a"
    },
    "spark_conf": {
      "spark.sql.shuffle.partitions": "2000",
      "spark.sql.adaptive.enabled": "true"
    }
  },
  "notebook_task": {
    "notebook_path": "/benchmark/Generate_TPCH_Simple",
    "base_parameters": {}
  },
  "timeout_seconds": 43200,
  "max_retries": 0
}
