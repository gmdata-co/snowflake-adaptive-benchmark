# ============================================
# SNOWFLAKE CONFIGURATION
# ============================================

# Connection name from ~/.snowflake/connections.toml
export SNOWFLAKE_CONNECTION=your_connection_name

# Snowflake database objects (user-specific)
export SNOWFLAKE_ROLE=BENCHMARK
export SNOWFLAKE_DATABASE=BENCHMARK
export SNOWFLAKE_SCHEMA=PUBLIC

# Snowflake warehouse naming prefix
# Actual warehouse names will be: {SNOWFLAKE_WAREHOUSE_PREFIX}_{SIZE}_{RUN_ID}
export SNOWFLAKE_WAREHOUSE_PREFIX=BENCHMARK_WH

# ============================================
# DATABRICKS CONFIGURATION
# ============================================

# Databricks workspace connection
export DATABRICKS_HOST=https://your-databricks-instance.cloud.databricks.com
export DATABRICKS_TOKEN=dapi_your_token_here

# Databricks catalog and schema (user-specific)
export DATABRICKS_CATALOG=your_catalog_name
export DATABRICKS_SCHEMA=your_schema_name

# Note: SQL Warehouses are created and destroyed automatically during benchmark runs
# No warehouse IDs need to be configured
